# F1 router-mode drive — PER-USER container secrets template.
#   cp .env.user.example .env.user
# `.env.user` is gitignored; this `.env.user.example` is committed as documentation.
# Runbook: apps/f1/test-drives/README-router-mode.md
#
# SCOPE: these are NOT env vars for the router-server process. They are one
# user's secrets, seeded into the router's SecretStore (<home>/secrets.json)
# via `./f1 router:seed-user`, and injected by the router into THAT USER's
# issue containers at boot (spread into the container env, minus reserved
# keys). Router/control-plane config lives in `.env` (see .env.example).
# Simulating multiple users? Keep one copy per user (e.g. .env.user.alice,
# .env.user.bob — `**/.env.*` is gitignored).
#
# These values are referenced on the SHELL command line, so source both files
# before seeding, from apps/f1:
#   set -a && source .env && source .env.user && set +a
#   ./f1 router:seed-user \
#     --email you@example.com \
#     --linear-id lin-you \
#     --claude-token "$CLAUDE_CODE_OAUTH_TOKEN" \
#     --env LINEAR_API_TOKEN="$LINEAR_API_TOKEN" \
#     --env GIT_TOKEN="$GIT_TOKEN" \
#     --env GIT_USER_NAME="$GIT_USER_NAME" \
#     --env GIT_USER_EMAIL="$GIT_USER_EMAIL"
#
# Rotation caveat: a container captures its env at boot. Re-seeding a secret
# only affects the next FRESH boot — destroy the issue's container first to
# apply immediately.
#
# Reserved keys (rejected by the store; router-controlled): CYRUS_ROUTER_URL,
# CYRUS_DEVICE_TOKEN, CYRUS_ISSUE_KEY, CYRUS_REPOS_JSON, CYRUS_WORKSPACES_DIR,
# CYRUS_REPO_CACHE_DIR, PATH, HOME, NODE_OPTIONS.

# ALWAYS REQUIRED: real Claude Code OAuth token (get one with: claude setup-token).
# The container runs a real Claude session with it; the router blocks boot for
# a user missing it, regardless of containers.requiredSecretKeys.
CLAUDE_CODE_OAUTH_TOKEN=

# Linear token — a Personal API Key or pre-obtained OAuth access token
# (interactive OAuth is NOT possible inside a container). When seeded, the
# container's Claude session gets the hosted Linear MCP authenticated with it.
LINEAR_API_TOKEN=

# GitHub token — needed if the container clones a PRIVATE repo or pushes/creates PRs.
GIT_TOKEN=

# Git identity for commits made inside the container.
# QUOTE values containing spaces (this file is `source`d by your shell):
#   GIT_USER_NAME="Ada Lovelace"
GIT_USER_NAME=
GIT_USER_EMAIL=

# Optional: per-user dotfiles repo; its install.sh runs at container boot.
# DOTFILES_REPO=
