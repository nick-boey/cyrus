# F1 router-mode drive — ROUTER/CONTROL-PLANE env template. Copy to `.env`:
#   cp .env.example .env
# `.env` is gitignored; this `.env.example` is committed as documentation.
# Runbook: apps/f1/test-drives/README-router-mode.md
#
# SCOPE: only config the router-server process and the ./f1 client read.
# Per-user container secrets (Claude token, Linear token, git creds) live in
# `.env.user.example` — the router never reads those from its own env; they
# are seeded per user via `./f1 router:seed-user` and injected into that
# user's containers at boot.
#
# Bun auto-loads `.env` for the ./f1 client run from apps/f1. The router
# server runs under NODE (better-sqlite3), which does not auto-load it:
#   node --env-file=.env dist/router-server.js

# Shared secret between router-server.ts and the ./f1 router:* client.
F1_ROUTER_CONTROL_TOKEN=f1-router-dev

# Pin the control port so the client URL below matches.
F1_ROUTER_CONTROL_PORT=3601

# Where ./f1 router:* commands send control requests (must match the port above).
F1_ROUTER_CONTROL_URL=http://127.0.0.1:3601

# Optional: comma-separated EXTRA env-var names every user must have seeded
# before their containers boot (CLAUDE_CODE_OAUTH_TOKEN is always required on
# top — the gate is additive). Set this to exercise the requiredSecretKeys
# boot gate during a drive: a user missing any listed key is blocked with a
# boot-failure activity naming it.
# F1_ROUTER_REQUIRED_SECRET_KEYS=LINEAR_API_TOKEN,GIT_TOKEN

# Optional: set to 1 to run router-server.ts with the NO-Docker fake executor.
# Do NOT set for a real credentialed drive.
# CYRUS_ROUTER_FAKE_EXECUTOR=1
