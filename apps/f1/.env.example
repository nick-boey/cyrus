# F1 router-mode drive — env template. Copy to `.env` and fill in your values.
#   cp .env.example .env
# `.env` is gitignored; this `.env.example` is committed as documentation.
# Runbook: apps/f1/test-drives/README-router-mode.md
#
# Bun auto-loads `.env` for processes started from apps/f1/ (router-server.ts
# and the ./f1 client), so vars read via process.env work with no extra step.
# For values referenced on the SHELL command line (the Claude token passed to
# `./f1 router:seed-user --claude-token "$CLAUDE_CODE_OAUTH_TOKEN"`), also run,
# from apps/f1:  set -a && source .env && set +a

# Your real Claude Code OAuth token (get one with: claude setup-token).
# The container runs a real Claude session with it.
CLAUDE_CODE_OAUTH_TOKEN=

# Shared secret between router-server.ts and the ./f1 router:* client.
F1_ROUTER_CONTROL_TOKEN=f1-router-dev

# Pin the control port so the client URL below matches.
F1_ROUTER_CONTROL_PORT=3601

# Where ./f1 router:* commands send control requests (must match the port above).
F1_ROUTER_CONTROL_URL=http://127.0.0.1:3601

# Optional: GitHub token, only if the container clones a PRIVATE repo.
# GIT_TOKEN=

# Optional: set to 1 to run router-server.ts with the NO-Docker fake executor.
# CYRUS_ROUTER_FAKE_EXECUTOR=1
